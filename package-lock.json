{
  "name": "aillive-code",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "aillive-code",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "bin": {
        "aillive": "apps/cli/src/index.js",
        "aillive-code": "apps/cli/src/index.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "apps/cli": {
      "name": "@aillive/cli",
      "version": "0.1.0",
      "bin": {
        "aillive": "src/index.js",
        "aillive-code": "src/index.js"
      },
      "engines": {
        "node": ">=18"
      }
    },
    "node_modules/@aillive/agent-runtime": {
      "resolved": "packages/agent-runtime",
      "link": true
    },
    "node_modules/@aillive/cli": {
      "resolved": "apps/cli",
      "link": true
    },
    "node_modules/@aillive/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@aillive/git": {
      "resolved": "packages/git",
      "link": true
    },
    "node_modules/@aillive/lsp": {
      "resolved": "packages/lsp",
      "link": true
    },
    "node_modules/@aillive/mcp": {
      "resolved": "packages/mcp",
      "link": true
    },
    "node_modules/@aillive/memory": {
      "resolved": "packages/memory",
      "link": true
    },
    "node_modules/@aillive/provider": {
      "resolved": "packages/provider",
      "link": true
    },
    "node_modules/@aillive/tui": {
      "resolved": "packages/tui",
      "link": true
    },
    "packages/agent-runtime": {
      "name": "@aillive/agent-runtime",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/core": {
      "name": "@aillive/core",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/git": {
      "name": "@aillive/git",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/lsp": {
      "name": "@aillive/lsp",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/mcp": {
      "name": "@aillive/mcp",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/memory": {
      "name": "@aillive/memory",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/provider": {
      "name": "@aillive/provider",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    },
    "packages/tui": {
      "name": "@aillive/tui",
      "version": "0.1.0",
      "engines": {
        "node": ">=18"
      }
    }
  }
