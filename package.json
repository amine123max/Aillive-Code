{
  "name": "@aillive/cli",
  "version": "0.1.0",
  "description": "Aillive Code command line AI assistant for terminal chat, project context, OpenAI-compatible APIs, and OpenClaw tasks.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "aillive": "src/index.js",
    "aillive-code": "src/index.js"
  },
  "files": [
    "apps/cli/src",
    "apps/cli/package.json",
    "packages/*/src/**",
    "packages/*/package.json",
    "src",
    "docs/assets/aillive-code-terminal.png",
    "docs/assets/aillive_code.png",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node ./apps/cli/src/index.js",
    "check": "npm run check:workspace && npm run check:syntax",
    "check:workspace": "node ./scripts/verify-workspace.mjs",
    "check:syntax": "node ./scripts/check-syntax.mjs",
    "check:release": "node ./scripts/check-release.mjs",
    "test": "node --test",
    "test:integration": "node --test test/cli.test.js",
    "smoke:npx": "npm run pack:smoke",
    "pack:smoke": "node ./scripts/pack-smoke.mjs",
    "pack:dry": "npm pack --dry-run",
    "publish:check": "npm run check && npm run check:release && npm test && npm run pack:smoke && npm run pack:dry"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "aillive",
    "aillive-code",
    "ai",
    "cli",
    "agent",
    "terminal",
    "openai",
    "openclaw"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amine123max/Aillive-Code.git"
  },
  "bugs": {
    "url": "https://github.com/amine123max/Aillive-Code/issues"
  },
  "homepage": "https://github.com/amine123max/Aillive-Code#readme",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@mimo-ai/plugin": "^0.1.4"
  }
}
